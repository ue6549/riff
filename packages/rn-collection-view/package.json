{
  "name": "riff",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "example"
  ],
  "description": "High-performance collection view for React Native New Architecture",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "cpp",
    "ios",
    "android",
    "CMakeLists.txt",
    "RNCollectionView.podspec",
    "!lib/typescript/example"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "build": "bob build --target commonjs --target module && (tsc --declaration --emitDeclarationOnly --declarationDir lib/typescript --noEmitOnError false || true)",
    "prepare": "yarn build",
    "example": "yarn workspace CollectionViewExample"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "collection-view",
    "virtualized-list"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TODO/rn-collection-view.git"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=19.2.0",
    "react-native": ">=0.83.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.83.0",
    "@types/react": "^19.2.14",
    "react-native-builder-bob": "0.35.0",
    "typescript": "^5.0.0"
  },
  "codegenConfig": {
    "name": "RNCollectionViewSpec",
    "type": "all",
    "jsSrcsDir": "src/specs",
    "ios": {
      "componentProvider": {
        "RNMeasuredCell": "RNMeasuredCellView",
        "RNScrollCoordinatedView": "RNScrollCoordinatedViewView",
        "RNCollectionViewContainer": "RNCollectionViewContainerView",
        "RNOrthogonalSectionView": "RNOrthogonalSectionView",
        "RNCollectionSubContainer": "RNCollectionSubContainerView"
      }
    },
    "android": {
      "javaPackageName": "com.rncollectionview"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esmodules": true
        }
      ],
      [
        "module",
        {
          "esmodules": true
        }
      ]
    ]
  }
}
